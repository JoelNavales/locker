rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user owns their profile document and their lockers subcollection.
    // No one can read or write another user's data.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /lockers/{lockerId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /tasks/{taskId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
